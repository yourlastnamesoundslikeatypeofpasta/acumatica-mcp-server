# Acumatica tenant configuration.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# You only need ONE credential source: this file OR your MCP client's `env` block,
# not both. If you set both, the env block wins and this file just fills in the gaps.

# Base URL of your Acumatica instance (no trailing slash).
ACUMATICA_BASE_URL=https://your-instance.acumatica.com

# Contract API endpoint path. Adjust the version segment to match your tenant
# (Help -> Web Service Endpoints in Acumatica shows the available versions).
ACUMATICA_ENDPOINT_PATH=/entity/Default/24.200.001

# Service account credentials. Use a dedicated integration account, not a person's login.
ACUMATICA_USERNAME=service_account
ACUMATICA_PASSWORD=

# Company/tenant code and optional branch, exactly as they appear in Acumatica.
ACUMATICA_COMPANY=
ACUMATICA_BRANCH=

ACUMATICA_LOCALE=en-US

# --- Write safety (read-only by default) ---
# Mutating tools are DISABLED unless you opt in, so the server cannot change data
# in the tenant by accident. Set to 1 only when you intend to allow writes.
# ACUMATICA_ALLOW_WRITES=0    # enables upsert_record and invoke_action
# ACUMATICA_ALLOW_DELETES=0   # enables delete_record

# --- Optional ---
# Select a different env file (absolute path, or a name relative to the package
# directory) so a single server can serve multiple tenants. Defaults to `.env`.
# ACUMATICA_ENV_FILE=.env.sandbox

# Log level: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
# ACUMATICA_LOG_LEVEL=INFO
